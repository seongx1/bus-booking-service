# 이 파일을 .env 로 복사한 뒤 값을 채우고, .env 는 Git에 커밋하지 마세요.
# 예: cp .env.example .env

# --- Cloudways API (scripts/cloudways-api.sh 사용 시) ---
CLOUDWAYS_EMAIL=your@email.com
CLOUDWAYS_API_KEY=your_api_key_here

# --- Cloudways SFTP (배포·슬랙 복구 시 자동 업로드용) ---
# Cloudways 대시보드 → 서버 → Master Credentials 에서 확인
# Public IP → CLOUDWAYS_SFTP_HOST, Username → CLOUDWAYS_SFTP_USER, Password → CLOUDWAYS_SFTP_PASSWORD
CLOUDWAYS_SFTP_HOST=
CLOUDWAYS_SFTP_USER=
CLOUDWAYS_SFTP_PASSWORD=
# 서버 ID (SFTP 호스트 비우면 API로 이 서버의 공용 IP 조회)
CLOUDWAYS_SERVER_ID=1574100
# 원격 경로 (Korea bus charter 앱: applications/tjjsevvqfe/public_html)
CLOUDWAYS_SFTP_REMOTE_PATH=applications/tjjsevvqfe/public_html

# --- Slack 알림 (배포 시 slack_webhook_config.php 자동 생성·업로드) ---
# 설정 시 dist/에 slack_webhook_config.php 가 만들어져 서버에 함께 올라갑니다.
# Slack 앱 → Incoming Webhooks 에서 URL 복사
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/Txxxx/Bxxxx/xxxx
