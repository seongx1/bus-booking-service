# Slack Webhook URL 보안을 위해 config.js는 제외
config.js
config/config.js

# Slack Webhook 설정 (배포 서버에서만 생성, Git 제외)
public/slack_webhook_config.php
dist/slack_webhook_config.php

# Cloudways API 키 (절대 커밋 금지)
.env
.env.local

# Cloudways 배포용 인증 정보 문서 (로컬 전용)
**/CLOUDWAYS_인증정보.md

# 배포용 venv (paramiko)
.venv_deploy

# 빌드 결과물 (dist 폴더는 포함하지만 백업은 제외)
dist/*.bak
dist/*.backup

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor files
.vscode/
.idea/
*.sublime-*

# 로그 파일
*.log
/tmp/
/slack_proxy.log

# 불필요한 중복 폴더 (정리됨 - 참고용)
# deploy_files/
# temp_deploy/
# public/

# Node modules (사용하는 경우)
node_modules/

# Python 캐시 (프록시 서버용)
__pycache__/
*.pyc
*.pyo

# 대용량 보관 파일 (로컬만)
dev/archive/기타/*.zip
